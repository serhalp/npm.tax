{
  "name": "npm.tax",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:analyze": "rm -rf .sonda/ && SONDA=true vite build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "pnpm run test:unit && pnpm run typecheck && pnpm run format:check && pnpm run lint",
    "test:unit": "node --test",
    "test:a11y": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@vercel/og": "^0.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.8.5",
    "typescript": "7.0.1-rc"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@e18e/eslint-plugin": "^0.5.1",
    "@netlify/vite-plugin-tanstack-start": "^1.3.16",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "knip": "^6.20.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "sonda": "^0.13.1",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=26.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
